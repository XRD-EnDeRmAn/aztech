# ===== TELEGRAM =====
# @BotFather-dan al
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID-ni almaq üçün @userinfobot-a yaz
TELEGRAM_CHAT_ID=your_chat_id_here

# ===== GROQ AI =====
# https://console.groq.com → API Keys → Create API Key (PULSUZDUR!)
GROQ_API_KEY=your_groq_api_key_here

# ===== SCHEDULER =====
# Neçə saatdan bir tarasın (default: 6)
SCAN_INTERVAL_HOURS=6

# ===== FİLTR =====
# Minimum əhəmiyyət balı 1-10 (default: 6) — altındakılar göndərilməz
MIN_IMPORTANCE_SCORE=6

# Hər taramada maksimum neçə xəbər emal edilsin (API qənaəti üçün)
MAX_ARTICLES_PER_RUN=40
